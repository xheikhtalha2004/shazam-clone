# =====================================================
# SoundFind — Next.js Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# =====================================================

# ── Supabase (public — safe to expose to browser) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Matcher API (public URL — safe to expose) ──────
NEXT_PUBLIC_MATCHER_API_URL=http://localhost:8000
# In production: https://your-render-service.onrender.com

# ── Admin API key (PUBLIC — required for recognize endpoint) ──
# This is also used in the browser to call /recognize directly.
# Keep this separate from ADMIN_API_KEY which is server-only.
NEXT_PUBLIC_MATCHER_API_KEY=your-shared-api-key

# ── Server-only (never exposed to browser) ─────────
# Used by /api/admin/ingest Route Handler to add auth header
MATCHER_API_URL=http://localhost:8000
ADMIN_API_KEY=your-shared-api-key
