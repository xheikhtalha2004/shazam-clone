# =====================================================
# SoundFind — Python Matcher API Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =====================================================

# ── Supabase (service role — server only, never expose) ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── API Security ────────────────────────────────────
# Must match ADMIN_API_KEY in the Next.js .env.local
ADMIN_API_KEY=your-shared-api-key

# ── CORS ────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app
